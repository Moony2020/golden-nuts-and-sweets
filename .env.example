# نسخة من هذا الملف باسم .env.local وعبّئ القيم

# رابط الاتصال بقاعدة MongoDB (من MongoDB Atlas)
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/food_company?retryWrites=true&w=majority

# رقم واتساب الشركة بصيغة دولية بدون + أو مسافات (مثال: 971547530333)
NEXT_PUBLIC_WHATSAPP_NUMBER=971547530333

# اسم الشركة (يظهر في الموقع)
NEXT_PUBLIC_COMPANY_NAME=شركة العدل للمواد الغذائية

# (اختياري) لإرسال نسخة من الطلبات على الإيميل لاحقاً
# SMTP_HOST=
# SMTP_USER=
# SMTP_PASS=
# NOTIFY_EMAIL=
